# Career-Ops India - Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# DATABASE
# =============================================================================
# Options: "sqlite" | "postgres"
DATABASE_PROVIDER=sqlite

# SQLite (default for local mode)
SQLITE_PATH=./data/career-ops.db

# PostgreSQL (for self-hosted / cloud mode)
# DATABASE_URL=postgres://user:password@localhost:5432/careerops

# =============================================================================
# AI PROVIDERS (all optional — configure via admin panel)
# =============================================================================
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=gsk_...
# OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# SERVER
# =============================================================================
PORT=3000
HOST=localhost

# =============================================================================
# SECURITY
# =============================================================================
# Auto-generated on first run if not set
# SESSION_SECRET=your-random-secret-here
# ENCRYPTION_KEY=your-32-char-encryption-key

# =============================================================================
# DEPLOYMENT MODE
# =============================================================================
# Options: "local" | "self-hosted" | "cloud" | "desktop"
DEPLOYMENT_MODE=local

# =============================================================================
# FEATURES
# =============================================================================
# Enable/disable features
ENABLE_AI=true
ENABLE_SCANNER=true
ENABLE_DESKTOP_FEATURES=false
